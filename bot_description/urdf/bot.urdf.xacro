<?xml version="1.0" ?>
<robot name="bot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="bot_ros2_control.xacro" />

  <xacro:property name="chassis_length" value="1.25"/>
  <xacro:property name="chassis_width" value="0.85"/>
  <xacro:property name="chassis_height" value="0.40"/>
  <xacro:property name="ground_clearance" value="0.20"/>
  <xacro:property name="payload_deck_height" value="0.08"/>
  <xacro:property name="payload_deck_length" value="0.95"/>
  <xacro:property name="payload_deck_width" value="0.65"/>
  <xacro:property name="base_mass" value="45.0"/>
  <xacro:property name="wheel_radius" value="0.28"/>
  <xacro:property name="wheel_width" value="0.14"/>
  <xacro:property name="wheel_mass" value="4.0"/>
  <xacro:property name="wheelbase" value="0.95"/>
  <xacro:property name="track_width" value="1.04"/>
  <xacro:property name="lidar_mast_height" value="0.55"/>
  <xacro:property name="base_z" value="${ground_clearance + chassis_height / 2.0}"/>
  <xacro:property name="wheel_z" value="${wheel_radius - base_z}"/>

  <xacro:macro name="wheel_link" params="name">
    <link name="${name}">
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia
          ixx="${wheel_mass * (3 * wheel_radius * wheel_radius + wheel_width * wheel_width) / 12.0}"
          iyy="${wheel_mass * (3 * wheel_radius * wheel_radius + wheel_width * wheel_width) / 12.0}"
          izz="${wheel_mass * wheel_radius * wheel_radius / 2.0}"
          ixy="0.0" ixz="0.0" iyz="0.0"/>
      </inertial>

      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="offroad_tire">
          <color rgba="0.04 0.04 0.04 1"/>
        </material>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="wheel_contact" params="link">
    <gazebo reference="${link}">
      <mu1>1.4</mu1>
      <mu2>0.9</mu2>
      <kp>500000.0</kp>
      <kd>50.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.2</maxVel>
      <fdir1>1 0 0</fdir1>
    </gazebo>
  </xacro:macro>


  <link name="base_footprint">
  </link>
    
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 ${base_z}" rpy="0.0 0.0 ${pi}"/>
  </joint>

<link name="base_link">
  <visual>
    <geometry>
      <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
    </geometry>
    <material name="gray">
      <color rgba="0.2 0.2 0.2 1" />
    </material>
  </visual>

  <visual>
    <origin xyz="0 0 ${chassis_height / 2.0 + payload_deck_height / 2.0}" rpy="0 0 0"/>
    <geometry>
      <box size="${payload_deck_length} ${payload_deck_width} ${payload_deck_height}"/>
    </geometry>
    <material name="payload_deck_black">
      <color rgba="0.08 0.08 0.08 1"/>
    </material>
  </visual>

  <collision>
    <geometry>
      <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
    </geometry>
  </collision>

  <collision>
    <origin xyz="0 0 ${chassis_height / 2.0 + payload_deck_height / 2.0}" rpy="0 0 0"/>
    <geometry>
      <box size="${payload_deck_length} ${payload_deck_width} ${payload_deck_height}"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="${base_mass}"/>
    <inertia
      ixx="${base_mass * (chassis_width * chassis_width + chassis_height * chassis_height) / 12.0}"
      iyy="${base_mass * (chassis_length * chassis_length + chassis_height * chassis_height) / 12.0}"
      izz="${base_mass * (chassis_length * chassis_length + chassis_width * chassis_width) / 12.0}"
      ixy="0.0" ixz="0.0" iyz="0.0"/>
  </inertial>
</link>


  <xacro:wheel_link name="wheel_front_right"/>
  <xacro:wheel_link name="wheel_front_left"/>
  <xacro:wheel_link name="wheel_back_right"/>
  <xacro:wheel_link name="wheel_back_left"/>

  <link name="rgb_camera">
    <inertial>
            <mass value="0.05" />
            <inertia ixx="0.01" ixy="0.0" ixz="0" 
            iyy="0.01" iyz="0" izz="0.01" />
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.12 0.10"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>


    <collision>
      <geometry>
          <box size="0.12 0.12 0.10"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="${-chassis_length / 2.0 - 0.08} 0 ${chassis_height / 2.0 - 0.05}" rpy="0 0.0 ${pi}"/>
    <parent link="base_link"/>
    <child link="rgb_camera"/>
    <axis xyz="0.0 0 0"/>
  </joint>

  <joint type="fixed" name="camera_optical_joint">
    <origin xyz="0 0 0" rpy="-1.5707 0 -1.5707"/>
    <child link="camera_link_optical"/>
    <parent link="rgb_camera"/>
  </joint>

  <link name="camera_link_optical">
  </link>

    <gazebo reference="rgb_camera">
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>15</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
        <optical_frame_id>camera_link_optical</optical_frame_id>
        <camera_info_topic>camera/camera_info</camera_info_topic>
      </camera>
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
    </sensor>
    </gazebo>


  <link name="laser_link">
    <inertial>
            <mass value="0.5" />
            <inertia ixx="0.01" ixy="0.0" ixz="0" 
            iyy="0.01" iyz="0" izz="0.01" />
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0  1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0 0 ${chassis_height / 2.0 + lidar_mast_height}" rpy="0 0.0 ${pi}"/>
    <parent link="base_link"/>
    <child link="laser_link"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

    <!-- 2D LIDAR 
  <gazebo reference="laser_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <topic>scan</topic>
      <update_rate>5</update_rate>
      <gz_frame_id>laser_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.00000</resolution>
            <min_angle>0.000000</min_angle>
            <max_angle>6.280000</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.120000</min>
          <max>12.0</max>
          <resolution>0.02</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>--> 

  <gazebo reference="laser_link">
    <sensor type="gpu_lidar" name="generic_lidar_sensor">
        <update_rate>15</update_rate>
        <visualize>false</visualize>
        <always_on>true</always_on>
        <frame_id>laser_link</frame_id>
        <ignition_frame_id>laser_link</ignition_frame_id>
        <topic>/lidar_3d</topic>
        <lidar>
          <scan>
            <horizontal>
              <samples>2400</samples>
              <resolution>1.0</resolution>
              <min_angle>-3.1415926</min_angle>
              <max_angle>3.1415926</max_angle>
            </horizontal>
            <vertical>
              <samples>32</samples>
              <resolution>1.0</resolution>
              <min_angle>-0.261799</min_angle>
              <max_angle>0.261799</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.3</min>
            <max>40</max>
            <resolution>0.02</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.025</stddev>
          </noise>
        </lidar>
    </sensor>
    <sensor type="gpu_lidar" name="generic_twold_lidar_sensor">
      <topic>/scan</topic>
      <frame_id>laser_link</frame_id>
      <ignition_frame_id>laser_link</ignition_frame_id>
      <update_rate>50.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>270</samples>
            <resolution>1</resolution>
            <min_angle>-${pi*0.75}</min_angle>
            <max_angle>${pi*0.75}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>8.0</max>
          <resolution>0.06</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.02</stddev>
        </noise>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <joint name="navsat_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="navsat_link" />
  </joint>

  <link name="navsat_link">
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="imu_link" />
  </joint>

  <link name="imu_link">
  </link>
  
   <gazebo reference="imu_link">
     <sensor name="imu_sensor" type="imu">
      <topic>/imu</topic>
      <frame_id>imu_link</frame_id>
      <ignition_frame_id>imu_link</ignition_frame_id>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
     <imu>
     	<angular_velocity>
     	  <x>
     	    <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
    </gazebo>

  <gazebo reference="navsat_link">
    <sensor name="navsat" type="navsat">
      <always_on>1</always_on>
      <update_rate>1</update_rate>
      <topic>navsat</topic>
      <gz_frame_id>navsat_link</gz_frame_id>
    </sensor>
  </gazebo>

  <joint name="wheel_front_right_joint" type="continuous">
    <origin xyz="${-wheelbase / 2.0} ${track_width / 2.0} ${wheel_z}" rpy="${pi / 2.0} 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_front_right"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>


  <joint name="wheel_front_left_joint" type="continuous">
    <origin xyz="${-wheelbase / 2.0} ${-track_width / 2.0} ${wheel_z}" rpy="${pi / 2.0} 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_front_left"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

  <joint name="wheel_back_right_joint" type="continuous">
    <origin xyz="${wheelbase / 2.0} ${track_width / 2.0} ${wheel_z}" rpy="${pi / 2.0} 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_back_right"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

  <joint name="wheel_back_left_joint" type="continuous">
    <origin xyz="${wheelbase / 2.0} ${-track_width / 2.0} ${wheel_z}" rpy="${pi / 2.0} 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_back_left"/>
    <axis xyz="0.0 0.0 1.0"/>

  </joint>

  <xacro:wheel_contact link="wheel_front_right"/>
  <xacro:wheel_contact link="wheel_front_left"/>
  <xacro:wheel_contact link="wheel_back_right"/>
  <xacro:wheel_contact link="wheel_back_left"/>

    <gazebo>
        <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
            <parameters>$(find bot_controller)/config/bot_controller.yaml</parameters>
        </plugin>
        <plugin filename="libignition-gazebo-imu-system.so" name="ignition::gazebo::systems::Imu">
          <initial_orientation_as_reference>false</initial_orientation_as_reference>
        </plugin>
        <plugin filename="libignition-gazebo-sensors-system.so" name="ignition::gazebo::systems::Sensors">
          <render_engine>ogre2</render_engine>
        </plugin>
        <plugin
        filename="ignition-gazebo-navsat-system"
        name="ignition::gazebo::systems::NavSat">
      </plugin>
    </gazebo>


</robot>
