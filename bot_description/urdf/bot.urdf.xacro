<?xml version="1.0" ?>
<robot name="bot" xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="bot_ros2_control.xacro" />

  <link name="base_footprint">
  </link>
    
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.50" rpy="0.0 0.0 3.14159"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="1.6 1.2 0.35"/>
      </geometry>
      <material name="gray">
        <color rgba="0.2 0.2 0.2 1" />
      </material>
    </visual>

    <collision>
      <geometry>
        <box size="1.6 1.2 0.35"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="80"/>
      <inertia ixx="15.0" iyy="22.0" izz="35.0" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <link name="wheel_front_right">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.18" iyy="0.18" izz="0.32" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_front_left">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.18" iyy="0.18" izz="0.32" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_back_right">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.18" iyy="0.18" izz="0.32" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
    </collision>
  </link>

  <link name="wheel_back_left">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.18" iyy="0.18" izz="0.32" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.28" length="0.20"/>
      </geometry>
    </collision>
  </link>

  <link name="rgb_camera">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="0.01" ixy="0.0" ixz="0" 
      iyy="0.01" iyz="0" izz="0.01" />
    </inertial>

    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <origin xyz="-0.35 0 0.15" rpy="0 0.0 3.14"/>

    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="-0.85 0 0.0" rpy="0 0.0 3.14"/>
    <parent link="base_link"/>
    <child link="rgb_camera"/>
    <axis xyz="0.0 0 0"/>
  </joint>

  <joint type="fixed" name="camera_optical_joint">
    <origin xyz="0 0 0" rpy="-1.5707 0 -1.5707"/>
    <child link="camera_link_optical"/>
    <parent link="rgb_camera"/>
  </joint>

  <link name="camera_link_optical">
  </link>

  <gazebo reference="rgb_camera">
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>15</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
        <optical_frame_id>camera_link_optical</optical_frame_id>
        <camera_info_topic>camera/camera_info</camera_info_topic>
      </camera>
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
    </sensor>
  </gazebo>

  <link name="thermal_camera">
    <inertial>
      <mass value="0.05" />
      <inertia ixx="0.01" ixy="0.0" ixz="0" 
      iyy="0.01" iyz="0" izz="0.01" />
    </inertial>
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <origin xyz="-0.35 0 0.15" rpy="0 0.0 3.14"/>
    <collision>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="thermal_camera_joint" type="fixed">
    <origin xyz="-0.85 0 0.20" rpy="0 0.0 3.14"/>
    <parent link="base_link"/>
    <child link="thermal_camera"/>
    <axis xyz="0.0 0 0"/>
  </joint>

  <gazebo reference="thermal_camera">
    <sensor name="thermal_camera_8bit" type="thermal">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>320</width>
          <height>240</height>
          <format>L8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>thermal_camera_8bit/image</topic>
      <plugin
        filename="ignition-gazebo-thermal-sensor-system"
        name="gz::sim::systems::ThermalSensor">
        <min_temp>253.15</min_temp>
        <max_temp>673.15</max_temp>
        <resolution>3.0</resolution>
      </plugin>
    </sensor>
  </gazebo>

  <link name="lidar_base">
    <inertial>
      <mass value="0.2" />
      <inertia ixx="0.005" ixy="0.0" ixz="0" 
      iyy="0.005" iyz="0" izz="0.005" />
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.08" length="0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_base_joint" type="fixed">
    <origin xyz="0 0 0.52" rpy="0 0.0 0"/>
    <parent link="base_link"/>
    <child link="lidar_base"/>
  </joint>

  <link name="laser_link">
    <inertial>
      <mass value="0.3" />
      <inertia ixx="0.008" ixy="0.0" ixz="0" 
      iyy="0.008" iyz="0" izz="0.012" />
    </inertial>

    <visual>
      <geometry>
        <cylinder radius="0.06" length="0.08"/>
      </geometry>
      <material name="lidar_black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.06" length="0.08"/>
      </geometry>
    </collision>
  </link>

  <link name="lidar_dome">
    <inertial>
      <mass value="0.1" />
      <inertia ixx="0.002" ixy="0.0" ixz="0" 
      iyy="0.002" iyz="0" izz="0.002" />
    </inertial>

    <visual>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
      <material name="lidar_transparent">
        <color rgba="0.2 0.2 0.2 0.6"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <sphere radius="0.055"/>
      </geometry>
    </collision>
  </link>

  <joint name="laser_joint" type="continuous">
    <origin xyz="0 0 0.03" rpy="0 0.0 0"/>
    <parent link="lidar_base"/>
    <child link="laser_link"/>
    <axis xyz="0.0 0.0 1.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="lidar_dome_joint" type="fixed">
    <origin xyz="0 0 0.04" rpy="0 0.0 0"/>
    <parent link="laser_link"/>
    <child link="lidar_dome"/>
  </joint>

  <gazebo reference="laser_link">
    <sensor type="gpu_lidar" name="generic_lidar_sensor">
      <update_rate>50</update_rate>
      <visualize>true</visualize>
      <always_on>true</always_on>
      <frame_id>laser_link</frame_id>
      <ignition_frame_id>laser_link</ignition_frame_id>
      <topic>/scan/points</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>1800</samples>
            <resolution>0.2</resolution>
            <min_angle>-3.1415926</min_angle>
            <max_angle>3.1415926</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <resolution>2</resolution>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>100</max>
          <resolution>0.001</resolution>
        </range>
      </lidar>
    </sensor>
    <sensor type="gpu_lidar" name="generic_twold_lidar_sensor">
      <topic>/scan</topic>
      <frame_id>laser_link</frame_id>
      <ignition_frame_id>laser_link</ignition_frame_id>
      <update_rate>50.0</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>270</samples>
            <resolution>1</resolution>
            <min_angle>-${pi*0.75}</min_angle>
            <max_angle>${pi*0.75}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>8.0</max>
          <resolution>0.06</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.02</stddev>
        </noise>
      </ray>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_base">
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="laser_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="lidar_dome">
    <material>Gazebo/GreyTransparent</material>
  </gazebo>

  <joint name="navsat_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="navsat_link" />
  </joint>

  <link name="navsat_link">
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="imu_link" />
  </joint>

  <link name="imu_link">
  </link>
  
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <topic>/imu</topic>
      <frame_id>imu_link</frame_id>
      <ignition_frame_id>imu_link</ignition_frame_id>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <gazebo reference="navsat_link">
    <sensor name="navsat" type="navsat">
      <always_on>1</always_on>
      <update_rate>1</update_rate>
      <topic>navsat</topic>
      <gz_frame_id>navsat_link</gz_frame_id>
    </sensor>
  </gazebo>

  <joint name="wheel_front_right_joint" type="continuous">
    <origin xyz="-0.60 0.70 -0.22" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_front_right"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <joint name="wheel_front_left_joint" type="continuous">
    <origin xyz="-0.60 -0.70 -0.22" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_front_left"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <joint name="wheel_back_right_joint" type="continuous">
    <origin xyz="0.60 0.70 -0.22" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_back_right"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <joint name="wheel_back_left_joint" type="continuous">
    <origin xyz="0.60 -0.70 -0.22" rpy="1.57 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_back_left"/>
    <axis xyz="0.0 0.0 1.0"/>
  </joint>

  <gazebo reference="wheel_front_right">
    <mu1>2.0</mu1>
    <mu2>1.8</mu2>
    <kp>200000.0</kp>
    <kd>20.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1</maxVel>
    <fdir1>1 0 0</fdir1>   
  </gazebo>

  <gazebo reference="wheel_front_left">
    <mu1>2.0</mu1>
    <mu2>1.8</mu2>
    <kp>200000.0</kp>
    <kd>20.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <gazebo reference="wheel_back_right">
    <mu1>2.0</mu1>
    <mu2>1.8</mu2>
    <kp>200000.0</kp>
    <kd>20.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <gazebo reference="wheel_back_left">
    <mu1>2.0</mu1>
    <mu2>1.8</mu2>
    <kp>200000.0</kp>
    <kd>20.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1</maxVel>
    <fdir1>1 0 0</fdir1>
  </gazebo>

  <gazebo>
    <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
      <parameters>$(find bot_controller)/config/bot_controller.yaml</parameters>
    </plugin>
    
    <plugin filename="libignition-gazebo-imu-system.so" name="ignition::gazebo::systems::Imu">
      <initial_orientation_as_reference>false</initial_orientation_as_reference>
    </plugin>
    
    <plugin filename="libignition-gazebo-sensors-system.so" name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    
    <plugin filename="ignition-gazebo-navsat-system" name="ignition::gazebo::systems::NavSat">
    </plugin>
  </gazebo>

  <link name="front_skid_plate">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.5 1.2 0.04"/>
      </geometry>
      <material name="steel">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 1.2 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="front_skid_joint" type="fixed">
    <origin xyz="-0.5 0 -0.25" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="front_skid_plate"/>
  </joint>

  <link name="rear_skid_plate">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.05" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.5 1.2 0.04"/>
      </geometry>
      <material name="steel">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.5 1.2 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="rear_skid_joint" type="fixed">
    <origin xyz="0.5 0 -0.25" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="rear_skid_plate"/>
  </joint>

  <link name="left_skid_plate">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.03" iyy="0.03" izz="0.03" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="1.6 0.1 0.04"/>
      </geometry>
      <material name="steel">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="1.6 0.1 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="left_skid_joint" type="fixed">
    <origin xyz="0 0.65 -0.25" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_skid_plate"/>
  </joint>

  <link name="right_skid_plate">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.03" iyy="0.03" izz="0.03" ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="1.6 0.1 0.04"/>
      </geometry>
      <material name="steel">
        <color rgba="0.7 0.7 0.7 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="1.6 0.1 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_skid_joint" type="fixed">
    <origin xyz="0 -0.65 -0.25" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_skid_plate"/>
  </joint>

  <gazebo reference="front_skid_plate">
    <mu1>0.4</mu1> 
    <mu2>0.4</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_skid_plate">
    <mu1>0.4</mu1>
    <mu2>0.4</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="left_skid_plate">
    <mu1>0.4</mu1>
    <mu2>0.4</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="right_skid_plate">
    <mu1>0.4</mu1>
    <mu2>0.4</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

</robot>